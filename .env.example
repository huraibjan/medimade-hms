# Supabase project settings (Dashboard -> Project Settings -> API)
# Use the BARE project URL (no /rest/v1 suffix). Never commit real values here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only secret. Never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the deployed app (used for auth email redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public portfolio demo credentials shown on the login page.
# Create this user in Supabase Auth before sharing the deployed app.
NEXT_PUBLIC_DEMO_LOGIN_EMAIL=admin@gmail.com
NEXT_PUBLIC_DEMO_LOGIN_PASSWORD=DemoAdmin2026!
